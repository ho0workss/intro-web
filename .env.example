# Vercel Postgres (자동 주입 - 대시보드에서 Postgres 연결 시 자동 설정됨)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob (자동 주입 - Blob 스토어 생성 시)
BLOB_READ_WRITE_TOKEN=

# Vercel KV (선택사항 - 사용 시 자동 주입)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# 사용자 직접 설정 필요 - DB 스키마 초기화용 비밀키
# 강력한 무작위 문자열로 설정 (예: openssl rand -hex 32)
INIT_KEY=your_random_init_key_here
